# ===========================================
# DocuMind AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Groq (required for LLM inference - RAG answers)
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Convex (vector store backend)
# ---------------------------------------------------------------------------
# Required. Use your DEPLOYMENT URL (e.g. https://your-deployment.convex.cloud).
# Do NOT use the dashboard URL (https://dashboard.convex.dev/...).
# Find it: Dashboard → project → Settings → Deployment URL, or run: npx convex dev (from packages/vector-store)
CONVEX_URL=

# ---------------------------------------------------------------------------
# Local embeddings (Ollama - nomic-embed-text). Optional; defaults below.
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# API Server (apps/api)
# ---------------------------------------------------------------------------
API_PORT=3001
NODE_ENV=development

# ---------------------------------------------------------------------------
# Next.js / Web (apps/web)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Optional: CORS (comma-separated origins). API only accepts requests from these.
# ---------------------------------------------------------------------------
# Add your LAN URL if you open the app at e.g. http://192.168.1.103:3000
# CORS_ORIGINS=http://localhost:3000,http://192.168.1.103:3000
